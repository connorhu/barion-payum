{
    "name": "codeconjure/barion-payum",
    "description": "Payum gateway bridge for Barion payment provider",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "payum/core": "^2.0",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "nyholm/psr7": "^1.8",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.0",
        "symfony/http-client": "^7.0"
    },
    "suggest": {
        "symfony/framework-bundle": "Required for PayumBundle integration",
        "symfony/http-client": "PSR-18 adapter for production use"
    },
    "autoload": {
        "psr-4": {
            "CodeConjure\\BarionPayum\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CodeConjure\\BarionPayum\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
